{
  "private": true,
  "name": "brandam",
  "version": "1.0.0",
  "description": "Simplified web app to manage, organize, and share your brand assets.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Yizack Rangel",
    "email": "yizackr@gmail.com",
    "url": "https://yizack.com"
  },
  "homepage": "https://github.com/Yizack/brandam",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yizack/brandam.git"
  },
  "bugs": "https://github.com/Yizack/brandam/issues",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --port=5173 --public",
    "generate": "nuxt generate",
    "preview": "wrangler d1 migrations apply DB --local && wrangler dev",
    "postinstall": "nuxt prepare",
    "analyze": "nuxt analyze",
    "db:migrate": "drizzle-kit generate --config=.config/drizzle.ts",
    "lint": "pnpm lint:eslint && pnpm lint:stylelint",
    "lint:fix": "pnpm lint:eslint --fix && pnpm lint:stylelint --fix",
    "lint:eslint": "eslint --config .config/eslint.mjs",
    "lint:eslint:inspect": "pnpm dlx @eslint/config-inspector --config .config/eslint.mjs",
    "lint:stylelint": "stylelint \"**/*.{css,scss,sass}\" --config .config/stylelint.json",
    "test:types": "vue-tsc -b --noEmit"
  },
  "dependencies": {
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/lucide": "^1.2.117",
    "@iconify-json/simple-icons": "^1.2.90",
    "@libsql/client": "^0.17.4",
    "@nuxt/ui": "^4.9.0",
    "@nuxthub/core": "^0.10.8",
    "@nuxtjs/sitemap": "^8.2.2",
    "@nuxtjs/turnstile": "^1.1.3",
    "@pinia/nuxt": "^1.0.0",
    "@tato30/vue-pdf": "^2.1.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "mime": "^4.1.0",
    "nuxt": "^4.4.8",
    "nuxt-auth-utils": "^0.5.29",
    "nuxt-email-renderer": "^2.8.0",
    "nuxt-mailchannels": "^0.4.4",
    "pinia": "^4.0.1",
    "sass-embedded": "^1.100.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@yizack/eslint-config": "^0.0.5",
    "eslint": "^10.7.0",
    "happy-dom": "^20.10.6",
    "nuxt-ui-colors-no-inline": "^0.0.5",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7",
    "wrangler": "^4.110.0"
  },
  "packageManager": "pnpm@11.13.0"
}
