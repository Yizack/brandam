{
  "private": true,
  "name": "brandam",
  "version": "1.0.0",
  "description": "Simplified web app to manage, organize, and share your brand assets.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Yizack Rangel",
    "email": "yizackr@gmail.com",
    "url": "https://yizack.com"
  },
  "homepage": "https://github.com/Yizack/brandam",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yizack/brandam.git"
  },
  "bugs": "https://github.com/Yizack/brandam/issues",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --port=5173 --public",
    "generate": "nuxt generate",
    "preview": "wrangler d1 migrations apply DB --local && wrangler dev",
    "postinstall": "nuxt prepare",
    "analyze": "nuxt analyze",
    "db:migrate": "drizzle-kit generate --config=.config/drizzle.ts",
    "lint": "pnpm lint:eslint && pnpm lint:stylelint",
    "lint:fix": "pnpm lint:eslint --fix && pnpm lint:stylelint --fix",
    "lint:eslint": "eslint --config .config/eslint.mjs",
    "lint:eslint:inspect": "pnpm dlx @eslint/config-inspector --config .config/eslint.mjs",
    "lint:stylelint": "stylelint \"**/*.{css,scss,sass}\" --config .config/stylelint.json",
    "test:types": "vue-tsc -b --noEmit"
  },
  "devDependencies": {
    "@iconify-json/logos": "^1.2.10",
    "@iconify-json/lucide": "^1.2.82",
    "@iconify-json/simple-icons": "^1.2.63",
    "@nuxt/eslint": "^1.12.1",
    "@nuxt/ui": "^4.3.0",
    "@nuxthub/core": "^0.10.3",
    "@nuxtjs/sitemap": "^7.5.0",
    "@nuxtjs/turnstile": "^1.1.1",
    "@pinia/nuxt": "^0.11.3",
    "@tato30/vue-pdf": "^1.11.5",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "eslint": "^9.39.2",
    "happy-dom": "^20.0.11",
    "mime": "^4.1.0",
    "nuxt": "^4.2.2",
    "nuxt-auth-utils": "^0.5.26",
    "nuxt-email-renderer": "^2.1.2",
    "nuxt-mailchannels": "^0.3.10",
    "pinia": "^3.0.4",
    "sass": "^1.97.1",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16",
    "vue-tsc": "^3.2.1",
    "wrangler": "^4.56.0",
    "zod": "^4.2.1"
  },
  "packageManager": "pnpm@10.26.1"
}
