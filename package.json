{
  "private": true,
  "name": "brandam",
  "version": "1.0.0",
  "description": "Yizack nuxt template",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Yizack Rangel",
    "email": "yizackr@gmail.com",
    "url": "https://yizack.com"
  },
  "homepage": "https://github.com/Yizack/brandam",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yizack/brandam.git"
  },
  "bugs": "https://github.com/Yizack/brandam/issues",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --port=5173 --host",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "analyze": "nuxt analyze",
    "db:migrate": "drizzle-kit generate --config=.config/drizzle.ts",
    "lint": "pnpm lint:eslint && pnpm lint:stylelint",
    "lint:fix": "pnpm lint:eslint --fix && pnpm lint:stylelint --fix",
    "lint:eslint": "eslint --config .config/eslint.mjs",
    "lint:eslint:inspect": "pnpm dlx @eslint/config-inspector --config .config/eslint.mjs",
    "lint:stylelint": "stylelint \"**/*.{css,scss,sass}\" --config .config/stylelint.json",
    "test:types": "vue-tsc --noEmit"
  },
  "devDependencies": {
    "@iconify-json/logos": "^1.2.4",
    "@iconify-json/lucide": "^1.2.45",
    "@iconify-json/simple-icons": "^1.2.37",
    "@nuxt/eslint": "^1.4.1",
    "@nuxt/icon": "^1.13.0",
    "@nuxt/ui": "^3.1.3",
    "@nuxthub/core": "^0.8.27",
    "@nuxtjs/sitemap": "^7.3.1",
    "@nuxtjs/turnstile": "^1.0.0",
    "@types/mime-types": "^3.0.0",
    "drizzle-kit": "^0.31.1",
    "drizzle-orm": "^0.44.2",
    "eslint": "^9.28.0",
    "mime-types": "^3.0.1",
    "nuxt": "^3.17.5",
    "nuxt-auth-utils": "^0.5.20",
    "sass": "^1.89.1",
    "stylelint": "^16.20.0",
    "stylelint-config-standard-scss": "^15.0.1",
    "typescript": "^5.8.3",
    "vue-tsc": "^2.2.10",
    "wrangler": "^4.19.1",
    "zod": "^3.25.51"
  },
  "packageManager": "pnpm@10.11.1"
}
